---
import type { UserSubjectCollection } from "@/types/bangumi";

interface Props {
	item: UserSubjectCollection;
	loadImage?: boolean;
}

const { item, loadImage = false } = Astro.props;
const { subject } = item;

// 核心修复：直接跳转到数据中定义的 url，点击卡片直接打开工具
const finalUrl = subject.url || `https://bgm.tv/subject/${subject.id}`;
---

<a
  href={finalUrl}
  target="_blank"
  rel="noopener noreferrer nofollow"
  class="group flex items-center gap-4 p-3 rounded-xl border border-(--line-divider) bg-(--card-bg) transition-all duration-300 hover:shadow-md hover:border-(--primary) hover:scale-[1.01] block overflow-hidden"
>
  <div class="w-14 h-14 shrink-0 rounded-lg overflow-hidden bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center">
    {subject.images?.medium ? (
      <img
        src={loadImage ? subject.images.medium : undefined}
        data-src={loadImage ? undefined : subject.images.medium}
        alt={subject.name_cn || subject.name}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="text-2xl">🚀</div>
    )}
  </div>

  <div class="flex-1 min-w-0">
    <div class="flex items-center">
      <h3 class="font-bold text-base text-neutral-900 dark:text-neutral-100 truncate group-hover:text-(--primary) transition-colors">
        {subject.name_cn || subject.name}
      </h3>
    </div>

    {subject.short_summary && (
      <p class="text-xs text-neutral-500 dark:text-neutral-400 line-clamp-1 mt-0.5 opacity-80">
        {subject.short_summary}
      </p>
    )}

    {subject.type && (
      <div class="flex gap-1 mt-1.5">
        <span class="text-[9px] px-1.5 py-0.5 rounded bg-neutral-100 dark:bg-neutral-800 text-neutral-400 font-medium uppercase tracking-wider">
          {subject.type === 3 ? "资源站" : subject.type === 4 ? "实用工具" : subject.type === 6 ? "在线编辑" : "项目"}
        </span>
      </div>
    )}
  </div>
</a>