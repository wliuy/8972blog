---
import { Icon } from "astro-icon/components";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { formatDateI18nWithTime } from "@/utils/date-utils";
import Card from "@/components/pages/bangumi/Card.astro";

// 🌟 引入你的本地项目数据
import { myProjects } from "./projectData";

// 获取构建时间
const buildTime = formatDateI18nWithTime(new Date());

// 定义分类过滤项，按你要求的顺序排列
// key 0:全部, 3:资源站, 4:实用工具, 6:在线编辑
const subjectTypeFilters = [
  { key: 0, label: i18n(I18nKey.bangumiFilterAll) },      
  { key: 3, label: i18n(I18nKey.bangumiCategoryMusic) },  
  { key: 4, label: i18n(I18nKey.bangumiCategoryGame) },   
  { key: 6, label: i18n(I18nKey.bangumiCategoryReal) },   
];
---

<MainGridLayout title={i18n(I18nKey.bangumi)} description={i18n(I18nKey.bangumiSubtitle)}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
        
        <div class="relative w-full mb-8 onload-animation">
            <div class="flex items-center gap-3 mb-3">
                <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
                    <Icon name="material-symbols:terminal" class="text-[1.5rem]"></Icon>
                </div>
                <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
                    {i18n(I18nKey.bangumi)}
                </div>
            </div>
            <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed">
                {i18n(I18nKey.bangumiSubtitle)}
            </p>
            <p class="text-xs text-neutral-500 dark:text-neutral-500 mt-2">
                {i18n(I18nKey.bangumiLastUpdated)} {buildTime} | {i18n(I18nKey.bangumiDataStatic)}
            </p>
        </div>

        <div class="flex flex-wrap gap-2 mb-10 onload-animation" style="animation-delay: 100ms">
          {
            subjectTypeFilters.map((type) => (
              <button
                data-type={type.key}
                class="filter-btn px-4 py-1.5 rounded-xl border border-(--line-divider) bg-(--card-bg) text-sm font-medium transition-all hover:border-(--primary) hover:text-(--primary) [&.active]:bg-(--primary) [&.active]:text-white [&.active]:border-(--primary)"
              >
                {type.label}
              </button>
            ))
          }
        </div>

        <div id="project-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4 onload-animation" style="animation-delay: 200ms">
          {
            myProjects.map((item) => (
              <div class="project-item block" data-category={item.subject.type}>
                <Card item={item} loadImage={true} />
              </div>
            ))
          }
        </div>

        {myProjects.length === 0 && (
          <div class="text-center py-16">
            <h2 class="text-xl font-semibold text-black/80 dark:text-white/80">
              {i18n(I18nKey.bangumiNoData)}
            </h2>
          </div>
        )}
    </div>
  </div>
</MainGridLayout>

<script>
  // 客户端实时过滤脚本
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.project-item');

  // 初始化：默认高亮“全部”
  document.querySelector('[data-type="0"]')?.classList.add('active');

  buttons.forEach(button => {
    button.addEventListener('click', () => {
      const selectedType = button.getAttribute('data-type');

      // 切换按钮样式
      buttons.forEach(btn => btn.classList.remove('active'));
      button.classList.add('active');

      // 过滤显示
      items.forEach(item => {
        const itemCategory = item.getAttribute('data-category');
        if (selectedType === '0' || itemCategory === selectedType) {
          (item as HTMLElement).style.display = 'block';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  /* 保持描述文字的简洁 */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>